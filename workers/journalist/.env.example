# fedwork-journalist — env contract (documented; no values here).
# Copy to .env and fill. .env is gitignored.

# ── data (required) ──
# Postgres connection string for the fedwork DB (reads flow/snapshot tables + posts).
DATABASE_URL=

# ── LLM (required) ──
# OpenRouter key. Model is unpinned → dynamic top-weekly-free selection.
OPENROUTER_API_KEY=

# ── web search (one of the two required; Firecrawl wins if both set) ──
# Firecrawl host — the public keyed proxy or a self-hosted host.
FIRECRAWL_API_URL=
FIRECRAWL_API_KEY=
# SearXNG JSON API base (fallback when FIRECRAWL_API_URL is unset).
SEARXNG_URL=

# ── embedding (optional) ──
# zerog-embedding /embed-batch host. Unset → trigram-only dedup (no near-paraphrase dedup).
EMBEDDING_URL=

# ── DataGod grounding (optional; unset → the DG block is skipped) ──
DATAGOD_URL=https://datagod.myclaudeapp.com
DATAGOD_API_KEY=

# ── publish / revalidate ──
# App origin the sink POSTs {"token": REVALIDATE_TOKEN} to at /api/revalidate after a write.
APP_URL=
# Public origin used to build the returned /insights/<slug> URL.
PUBLIC_URL=
# Shared secret for the /api/revalidate route (timing-safe compared server-side).
REVALIDATE_TOKEN=

# ── worker knobs ──
# Cron (6-field, seconds-first). Default hourly at :30.
JOURNALIST_CRON=0 30 * * * *
# draft | live. Default draft (a live value publishes immediately).
JOURNALIST_PUBLISH=draft
# Comma-separated bylines. Default "LevelsGov Staff".
JOURNALIST_BYLINES=
# Pinned OpenRouter model. Unset → dynamic top-weekly-free selection (which can
# land on a small model that summarizes the article on rewrite passes and trips
# the engine's 800-word floor). Pin a large instruction-follower, e.g.
# openai/gpt-oss-120b:free, for reliable full-length rewrites.
JOURNALIST_MODEL=
# Per-cycle watchdog (ms). A cycle exceeding this exits the process for a clean
# Coolify restart (a promise can't be cancelled), bounding a stall and making
# cron overlap impossible. MUST exceed a normal cycle (~30 min). Default 2400000
# (40 min). Keep below the cron interval.
JOURNALIST_RUN_TIMEOUT_MS=
# Per-LLM-call timeout (ms) handed to @openrouter/sdk's native timeoutMs — a hung
# free-model response aborts and the per-model retry advances. Default 120000.
OPENROUTER_CALL_TIMEOUT_MS=
# HTTP port for GET /health. Default 8090.
PORT=
